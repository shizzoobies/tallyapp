{
  "name": "tally",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "wrangler pages dev dist --live-reload --port 8788",
    "dev": "npm run build && concurrently -k -n vite,cf \"npm:build:watch\" \"npm:preview\"",
    "test": "vitest run",
    "db:local": "wrangler d1 execute tally --file schema.sql --local",
    "db:remote": "wrangler d1 execute tally --file schema.sql --remote"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240101.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  }
}
